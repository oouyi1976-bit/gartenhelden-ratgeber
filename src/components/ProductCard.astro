---
import type { GardenProduct } from "@/data/gardenProducts";

interface Props {
  product: GardenProduct;
}

const { product } = Astro.props;
const isReady = product.affiliateStatus === "ready" && product.affiliateUrl.length > 0;
---

<article class="group overflow-hidden rounded-[1.75rem] border border-sage-900/10 bg-white shadow-card transition duration-300 hover:-translate-y-1 hover:shadow-soft">
  <div class="aspect-[4/3] overflow-hidden bg-sage-50">
    {isReady ? (
      <a href={product.affiliateUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" class="focus-ring block h-full">
        <img
          src={product.image}
          alt={product.title}
          loading="lazy"
          class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
        />
      </a>
    ) : (
      <img
        src={product.image}
        alt={product.title}
        loading="lazy"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      />
    )}
  </div>
  <div class="flex min-h-64 flex-col p-5">
    <p class="text-xs font-bold uppercase tracking-[0.16em] text-sage-700">{product.category}</p>
    {isReady ? (
      <a href={product.affiliateUrl} target="_blank" rel="nofollow sponsored noopener noreferrer" class="focus-ring mt-2 rounded-md">
        <h3 class="font-serif text-xl font-bold leading-tight text-charcoal">{product.title}</h3>
      </a>
    ) : (
      <h3 class="mt-2 font-serif text-xl font-bold leading-tight text-charcoal">{product.title}</h3>
    )}
    <p class="mt-3 flex-1 text-sm leading-6 text-charcoal/70">{product.description}</p>
    {isReady ? (
      <a
        href={product.affiliateUrl}
        target="_blank"
        rel="nofollow sponsored noopener noreferrer"
        class="focus-ring mt-5 inline-flex items-center justify-center rounded-full bg-bark px-4 py-2.5 text-sm font-bold text-white transition hover:bg-walnut"
      >
        {product.buttonText}
      </a>
    ) : (
      <span class="mt-5 inline-flex items-center justify-center rounded-full border border-sage-900/15 bg-sage-50 px-4 py-2.5 text-sm font-bold text-sage-800">
        {product.buttonText}
      </span>
    )}
  </div>
</article>
