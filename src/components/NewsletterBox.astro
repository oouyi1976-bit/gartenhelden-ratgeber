---
---

<section class="rounded-[2rem] border border-sage-900/10 bg-sage-800 p-6 text-white shadow-soft sm:p-8">
  <div class="grid gap-6 lg:grid-cols-[1fr_0.95fr] lg:items-center">
    <div>
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-sage-200">Gartenpost</p>
      <h2 class="mt-3 font-serif text-3xl font-bold leading-tight">Saisonideen vormerken</h2>
      <p class="mt-3 text-sm leading-6 text-white/78">
        Eine ruhige Magazin-Box für spätere Newsletter-Pläne. Aktuell werden hier keine Daten übertragen.
      </p>
    </div>
    <form class="grid gap-3 sm:grid-cols-[1fr_auto]" onsubmit="event.preventDefault()">
      <label class="sr-only" for="newsletter-email">E-Mail-Adresse</label>
      <input
        id="newsletter-email"
        type="email"
        placeholder="E-Mail-Adresse"
        class="focus-ring min-h-12 rounded-full border border-white/20 bg-white px-4 text-sm text-charcoal placeholder:text-charcoal/45"
      />
      <button
        type="submit"
        class="focus-ring min-h-12 rounded-full bg-cream px-5 text-sm font-bold text-sage-900 transition hover:bg-white"
      >
        Merken
      </button>
    </form>
  </div>
</section>
