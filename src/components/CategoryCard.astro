---
import type { GardenCategory } from "@/data/categories";

interface Props {
  category: GardenCategory;
}

const { category } = Astro.props;
---

<a
  href={`/${category.slug}/`}
  class="focus-ring group grid overflow-hidden rounded-[1.75rem] border border-sage-900/10 bg-white shadow-card transition duration-300 hover:-translate-y-1 hover:shadow-soft"
>
  <div class="aspect-[5/3] overflow-hidden bg-sage-50">
    <img
      src={category.image}
      alt={category.title}
      loading="lazy"
      class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
    />
  </div>
  <div class="p-5">
    <h3 class="font-serif text-2xl font-bold text-charcoal">{category.title}</h3>
    <p class="mt-3 text-sm leading-6 text-charcoal/70">{category.description}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {category.highlights.map((highlight) => (
        <span class="rounded-full bg-sage-50 px-3 py-1 text-xs font-bold text-sage-800">{highlight}</span>
      ))}
    </div>
  </div>
</a>
