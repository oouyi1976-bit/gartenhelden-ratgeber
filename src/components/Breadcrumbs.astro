---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="container-page py-5 text-sm text-charcoal/60" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-2">
    <li><a href="/" class="hover:text-sage-800">Start</a></li>
    {items.map((item) => (
      <>
        <li aria-hidden="true">/</li>
        <li>
          {item.href ? (
            <a href={item.href} class="hover:text-sage-800">{item.label}</a>
          ) : (
            <span class="font-semibold text-charcoal">{item.label}</span>
          )}
        </li>
      </>
    ))}
  </ol>
</nav>
