---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AffiliateNotice from "@/components/AffiliateNotice.astro";
import HeroSection from "@/components/HeroSection.astro";
import CategoryCard from "@/components/CategoryCard.astro";
import ProductCard from "@/components/ProductCard.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import NewsletterBox from "@/components/NewsletterBox.astro";
import { categories } from "@/data/categories";
import { gardenProducts } from "@/data/gardenProducts";
import { articles } from "@/data/articles";

const popularProducts = gardenProducts.slice(0, 8);
const teaserArticles = articles.slice(0, 6);
---

<BaseLayout
  title="GartenHelden Ratgeber"
  description="Deutsches Garten-Magazin mit seriösen Ratgebern, kuratierter Produktauswahl und lokalen Bildern für Beet, Balkon, Rasen und Terrasse."
>
  <HeroSection />
  <AffiliateNotice />

  <section class="container-page py-16 sm:py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">Gartenbereiche</p>
      <h2 class="mt-3 font-serif text-4xl font-bold leading-tight text-charcoal sm:text-5xl">
        Alles für Beet, Balkon, Rasen und Terrasse
      </h2>
      <p class="mt-4 text-lg leading-8 text-charcoal/70">
        Die Kategorien bündeln sinnvolle Helfer und praktische Orientierung, ohne künstliche Testsieger oder erfundene Bewertungen.
      </p>
    </div>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {categories.map((category) => <CategoryCard category={category} />)}
    </div>
  </section>

  <section class="bg-linen/65 py-16 sm:py-20">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-3xl">
          <p class="eyebrow">Produktempfehlungen</p>
          <h2 class="mt-3 font-serif text-4xl font-bold leading-tight text-charcoal sm:text-5xl">
            Beliebte Gartenprodukte
          </h2>
          <p class="mt-4 text-lg leading-8 text-charcoal/70">
            Eine vorsichtige Auswahl typischer Gartenhelfer. Amazon-Ziele werden erst eingebunden, wenn ein konkreter DP-Link redaktionell geprüft ist.
          </p>
        </div>
        <a href="/beste-gartenprodukte/" class="focus-ring inline-flex rounded-full bg-sage-700 px-5 py-3 text-sm font-bold text-white transition hover:bg-sage-800">
          Alle Produkte ansehen
        </a>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {popularProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="container-page py-16 sm:py-20">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-3xl">
        <p class="eyebrow">Ratgeber</p>
        <h2 class="mt-3 font-serif text-4xl font-bold leading-tight text-charcoal sm:text-5xl">
          Ruhige Hilfe für die nächste Gartenrunde
        </h2>
        <p class="mt-4 text-lg leading-8 text-charcoal/70">
          Verständliche Artikel für typische Fragen rund um Pflege, Planung, Bewässerung und Aufbewahrung.
        </p>
      </div>
      <a href="/ratgeber/" class="focus-ring inline-flex rounded-full border border-sage-900/15 bg-white px-5 py-3 text-sm font-bold text-sage-900 shadow-card transition hover:bg-sage-50">
        Alle Ratgeber
      </a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {teaserArticles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <section class="container-page pb-16 sm:pb-20">
    <NewsletterBox />
  </section>
</BaseLayout>
