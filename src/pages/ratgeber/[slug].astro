---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import ProductCard from "@/components/ProductCard.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { articles, type GardenArticle } from "@/data/articles";
import { productsByCategory } from "@/data/gardenProducts";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: GardenArticle;
}

const { article } = Astro.props;
const relatedProducts = productsByCategory(article.category).slice(0, 4);
const relatedArticles = articles
  .filter((candidate) => candidate.category === article.category && candidate.slug !== article.slug)
  .slice(0, 3);
---

<BaseLayout title={article.title} description={article.description} ogImage={article.image}>
  <Breadcrumbs items={[{ label: "Ratgeber", href: "/ratgeber/" }, { label: article.title }]} />

  <article>
    <header class="container-page pb-10 pt-3">
      <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
        <div>
          <p class="eyebrow">{article.category} · {article.readingTime}</p>
          <h1 class="mt-3 font-serif text-4xl font-bold leading-tight text-charcoal sm:text-6xl">
            {article.title}
          </h1>
          <p class="mt-5 text-lg leading-8 text-charcoal/70">{article.description}</p>
          <p class="mt-4 text-sm font-semibold text-charcoal/55">Aktualisiert am {new Date(article.updatedAt).toLocaleDateString("de-DE")}</p>
        </div>
        <div class="overflow-hidden rounded-[2rem] shadow-soft">
          <img src={article.image} alt={article.title} class="aspect-[5/3] h-full w-full object-cover" />
        </div>
      </div>
    </header>

    <div class="container-page grid gap-12 pb-16 lg:grid-cols-[minmax(0,760px)_1fr]">
      <div class="grid gap-10 rounded-[2rem] bg-white p-6 shadow-card sm:p-10">
        {article.sections.map((section) => (
          <section>
            <h2 class="font-serif text-3xl font-bold leading-tight text-charcoal">{section.heading}</h2>
            <div class="mt-4 grid gap-4">
              {section.body.map((paragraph) => (
                <p class="text-base leading-8 text-charcoal/74">{paragraph}</p>
              ))}
            </div>
          </section>
        ))}
      </div>

      <aside class="lg:sticky lg:top-28 lg:self-start">
        <div class="rounded-[2rem] border border-sage-900/10 bg-sage-50 p-6 shadow-card">
          <h2 class="font-serif text-2xl font-bold text-charcoal">Passende Kategorie</h2>
          <p class="mt-3 text-sm leading-6 text-charcoal/70">
            Weitere Produktauswahl und Orientierung findest du in der Kategorie {article.category}.
          </p>
          <a href={`/${article.category === "Gartengeräte" ? "gartengeraete" : article.category === "Rasenpflege" ? "rasenpflege" : article.category === "Hochbeet" ? "hochbeet" : article.category === "Bewässerung" ? "bewaesserung" : article.category === "Gartenmöbel" ? "gartenmoebel" : article.category === "Balkon-Garten" ? "balkon-garten" : article.category === "Pflanzenpflege" ? "pflanzenpflege" : "ordnung-aufbewahrung"}/`} class="focus-ring mt-5 inline-flex rounded-full bg-sage-700 px-4 py-2.5 text-sm font-bold text-white hover:bg-sage-800">
            Kategorie öffnen
          </a>
        </div>
      </aside>
    </div>
  </article>

  {relatedProducts.length > 0 && (
    <section class="bg-linen/65 py-16 sm:py-20">
      <div class="container-page">
        <div class="max-w-3xl">
          <p class="eyebrow">Produktauswahl</p>
          <h2 class="mt-3 font-serif text-4xl font-bold leading-tight text-charcoal">Passende Gartenhelfer</h2>
        </div>
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {relatedProducts.map((product) => <ProductCard product={product} />)}
        </div>
      </div>
    </section>
  )}

  {relatedArticles.length > 0 && (
    <section class="container-page py-16 sm:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow">Weiterlesen</p>
        <h2 class="mt-3 font-serif text-4xl font-bold leading-tight text-charcoal">Ähnliche Ratgeber</h2>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {relatedArticles.map((relatedArticle) => <ArticleCard article={relatedArticle} />)}
      </div>
    </section>
  )}
</BaseLayout>
